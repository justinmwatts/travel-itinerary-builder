# Copy to apps/api/.env and fill in. Never commit the real .env.
# All secrets live server-side only and are never shipped to the client.

# Prisma / SQLite
DATABASE_URL="file:./dev.db"

# API server
PORT=4000
WEB_ORIGIN="http://localhost:5173"

# Auth (Phase 2)
JWT_SECRET="replace-with-a-long-random-string"

# Anthropic Messages API (Phase 3)
ANTHROPIC_API_KEY="sk-ant-..."

# Pexels image proxy (Phase 6)
PEXELS_KEY="your-pexels-api-key"
