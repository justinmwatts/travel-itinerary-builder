{
  "name": "travel-itinerary-builder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "yarn workspace @travel/api dev",
    "dev:web": "yarn workspace @travel/web dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "yarn workspace @travel/shared typecheck && yarn workspace @travel/api typecheck && yarn workspace @travel/web typecheck",
    "test": "yarn workspace @travel/shared test && yarn workspace @travel/api test && yarn workspace @travel/web test",
    "db:migrate": "yarn workspace @travel/api db:migrate",
    "db:seed": "yarn workspace @travel/api db:seed",
    "db:generate": "yarn workspace @travel/api db:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
